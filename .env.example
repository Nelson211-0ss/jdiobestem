# Copy to .env for local serverless dev (do not commit .env)
# Stripe Dashboard → Developers → API keys
# Local/preview: sk_test_…   Netlify Production context: sk_live_… only (enforced in code)

STRIPE_SECRET_KEY=sk_test_your_secret_key

# Stripe webhook signing secret (Dashboard → Developers → Webhooks → your endpoint).
# Locally, `stripe listen --forward-to localhost:3000/api/stripe-webhook` prints a whsec_… to use.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# --- Optional donation notifications (all off unless set) ---
# Email each donation via Resend (https://resend.com). Needs all three:
# RESEND_API_KEY=re_your_key
# DONATION_NOTIFY_EMAIL=you@yourorg.org           # who gets the alert
# DONATION_FROM_EMAIL=donations@yourdomain.org    # a sender on a Resend-verified domain
#
# Append each donation to a Google Sheet via an Apps Script web app (see README):
# GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# Local/preview only: skip Stripe in create-checkout-session. Ignored when CONTEXT=production or SITE_ENV=production.
# MOCK_CHECKOUT=1

# Netlify Production + deploy previews: canonical public origin (no trailing slash)
# PUBLIC_SITE_URL=https://www.yoursite.org

# Non-Netlify production servers running this repo’s function: set so mock mode and sk_test_ are rejected
# SITE_ENV=production
